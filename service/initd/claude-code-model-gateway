#!/bin/sh
### BEGIN INIT INFO
# Provides:          claude-code-model-gateway
# Required-Start:    $network $remote_fs $syslog
# Required-Stop:     $network $remote_fs $syslog
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Claude Code Model Gateway
# Description:       HTTP model gateway/proxy service for Claude Code
#                    with multi-provider AI backend support.
### END INIT INFO

# ---------------------------------------------------------------------------
# SysV init script for claude-code-model-gateway
# ---------------------------------------------------------------------------

NAME="claude-code-model-gateway"
DESC="Claude Code Model Gateway"
DAEMON="/opt/claude-code-model-gateway/venv/bin/claude-code-model-gateway"
DAEMON_ARGS="gateway"
PIDFILE="/var/run/${NAME}/${NAME}.pid"
LOGFILE="/var/log/${NAME}/gateway.log"
RUN_AS="claude-gateway"
CONFIG_DIR="/etc/${NAME}"
ENV_FILE="${CONFIG_DIR}/environment"

# Read configuration defaults
if [ -f "${ENV_FILE}" ]; then
    . "${ENV_FILE}"
fi

# Apply defaults
GATEWAY_HOST="${GATEWAY_HOST:-0.0.0.0}"
GATEWAY_PORT="${GATEWAY_PORT:-8080}"
GATEWAY_TIMEOUT="${GATEWAY_TIMEOUT:-300}"
GATEWAY_LOG_FORMAT="${GATEWAY_LOG_FORMAT:-json}"
GATEWAY_LOG_FILE="${GATEWAY_LOG_FILE:-${LOGFILE}}"

DAEMON_ARGS="gateway --host ${GATEWAY_HOST} --port ${GATEWAY_PORT} --timeout ${GATEWAY_TIMEOUT} --log-format ${GATEWAY_LOG_FORMAT} --log-file ${GATEWAY_LOG_FILE}"

# Load LSB init functions
. /lib/lsb/init-functions

# Ensure runtime dirs exist
ensure_dirs() {
    mkdir -p "/var/run/${NAME}"
    mkdir -p "/var/log/${NAME}"
    mkdir -p "/var/lib/${NAME}"
    chown "${RUN_AS}:${RUN_AS}" "/var/run/${NAME}"
    chown "${RUN_AS}:${RUN_AS}" "/var/log/${NAME}"
    chown "${RUN_AS}:${RUN_AS}" "/var/lib/${NAME}"
}

is_running() {
    if [ -f "${PIDFILE}" ]; then
        PID=$(cat "${PIDFILE}")
        if kill -0 "${PID}" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

do_start() {
    if is_running; then
        log_warning_msg "${DESC} is already running (PID $(cat ${PIDFILE}))"
        return 0
    fi

    ensure_dirs

    log_daemon_msg "Starting ${DESC}" "${NAME}"
    start-stop-daemon --start --quiet --background \
        --make-pidfile --pidfile "${PIDFILE}" \
        --chuid "${RUN_AS}" \
        --exec "${DAEMON}" -- ${DAEMON_ARGS}
    RETVAL=$?

    if [ ${RETVAL} -eq 0 ]; then
        log_end_msg 0
    else
        log_end_msg 1
    fi
    return ${RETVAL}
}

do_stop() {
    if ! is_running; then
        log_warning_msg "${DESC} is not running"
        return 0
    fi

    log_daemon_msg "Stopping ${DESC}" "${NAME}"
    start-stop-daemon --stop --quiet --retry=TERM/30/KILL/5 \
        --pidfile "${PIDFILE}" --exec "${DAEMON}"
    RETVAL=$?
    rm -f "${PIDFILE}"

    if [ ${RETVAL} -eq 0 ]; then
        log_end_msg 0
    else
        log_end_msg 1
    fi
    return ${RETVAL}
}

do_restart() {
    do_stop
    sleep 1
    do_start
}

do_status() {
    if is_running; then
        PID=$(cat "${PIDFILE}")
        log_success_msg "${DESC} is running (PID ${PID})"
        return 0
    else
        log_failure_msg "${DESC} is not running"
        return 3
    fi
}

do_reload() {
    if ! is_running; then
        log_failure_msg "${DESC} is not running"
        return 1
    fi

    log_daemon_msg "Reloading ${DESC}" "${NAME}"
    kill -HUP "$(cat ${PIDFILE})"
    log_end_msg $?
}

case "$1" in
    start)
        do_start
        ;;
    stop)
        do_stop
        ;;
    restart|force-reload)
        do_restart
        ;;
    reload)
        do_reload
        ;;
    status)
        do_status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload|force-reload|status}" >&2
        exit 1
        ;;
esac

exit $?
