# /etc/claude-code-model-gateway/environment
# Environment configuration for claude-code-model-gateway service
#
# This file is sourced by both systemd and SysV init scripts.
# Uncomment and modify values as needed.

# ---------------------------------------------------------------------------
# Gateway server settings
# ---------------------------------------------------------------------------

# Host address to bind to (use 0.0.0.0 for all interfaces)
GATEWAY_HOST=0.0.0.0

# Port to listen on
GATEWAY_PORT=8080

# Upstream connection timeout in seconds
GATEWAY_TIMEOUT=300

# ---------------------------------------------------------------------------
# Logging settings
# ---------------------------------------------------------------------------

# Log format: standard, detailed, json, colored, minimal
GATEWAY_LOG_FORMAT=json

# Log file path
GATEWAY_LOG_FILE=/var/log/claude-code-model-gateway/gateway.log

# Log level override (debug, info, warning, error)
# GATEWAY_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Provider API keys
# Set these to enable the respective providers.
# WARNING: Protect this file — it contains secrets.
#          Ensure permissions are 0600 or 0640 owned by root:claude-gateway.
# ---------------------------------------------------------------------------

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# AZURE_OPENAI_API_KEY=...

# ---------------------------------------------------------------------------
# Advanced settings
# ---------------------------------------------------------------------------

# Default provider name
# GATEWAY_DEFAULT_PROVIDER=anthropic

# Max retries for upstream requests
# GATEWAY_MAX_RETRIES=3

# Path to gateway YAML/JSON configuration file
# GATEWAY_CONFIG=/etc/claude-code-model-gateway/gateway.yaml
