# Files to include in source distributions beyond the defaults
include pyproject.toml
include requirements.txt
include CLAUDE.md
include Makefile
include Dockerfile
include docker-compose.yaml

# Service packaging files
recursive-include service *
recursive-include scripts *

# Exclude dev/test/build artifacts
exclude .gitignore
recursive-exclude tests *
recursive-exclude .factory *
recursive-exclude .pytest_cache *
recursive-exclude __pycache__ *
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.egg-info
